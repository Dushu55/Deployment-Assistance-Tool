            {
              "id": "Component_Evaluator-COMP-APICALL-NO-ERROR-HANDLING",
              "shortDescription": {
                "text": "State-changing API call POST ${url}/api/v2/import-scan/ has no error handling — a failed request fai"
              },
              "fullDescription": {
                "text": "State-changing API call POST ${url}/api/v2/import-scan/ has no error handling — a failed request fails silently or crashes the UI."
              },
              "help": {
                "text": "Wrap the call in try/catch (or add .catch) and surface the failure to the user; never assume a mutating request succeeds."
              }
            }
          ]
        }
