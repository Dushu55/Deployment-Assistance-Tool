            {
              "id": "Semgrep-python.lang.security.audit.dynamic-urllib-use-detected.dynamic-urllib-use-detected",
              "shortDescription": {
                "text": "Detected a dynamic value being used with urllib. urllib supports 'file://' schemes, so a dynamic val"
              },
              "fullDescription": {
                "text": "Detected a dynamic value being used with urllib. urllib supports 'file://' schemes, so a dynamic value controlled by a malicious actor may allow them to read arbitrary files. Audit uses of urllib calls to ensure user data cannot control the URLs, or consider using the 'requests' library instead."
              },
              "help": {
                "text": "No remediation provided."
              }
            },
            {
              "id": "Semgrep-rules.dat-no-process-exit",
              "shortDescription": {
                "text": "Avoid using process.exit() in application code. It abruptly terminates the Node.js process. Throw an"
              },
              "fullDescription": {
                "text": "Avoid using process.exit() in application code. It abruptly terminates the Node.js process. Throw an error instead."
              },
              "help": {
                "text": "No remediation provided."
              }
            },
            {
              "id": "Semgrep-javascript.lang.security.detect-child-process.detect-child-process",
              "shortDescription": {
                "text": "Detected calls to child_process from a function argument `command`. This could lead to a command inj"
              },
              "fullDescription": {
                "text": "Detected calls to child_process from a function argument `command`. This could lead to a command injection if the input is user controllable. Try to avoid calls to child_process, and if it is needed ensure user input is correctly sanitized or sandboxed. "
              },
              "help": {
                "text": "No remediation provided."
              }
            },
            {
              "id": "Semgrep-rules.dat-no-todo-fixme",
              "shortDescription": {
                "text": "Unresolved TODO, FIXME, or HACK comment found. Ensure this technical debt is tracked in Jira."
              },
              "fullDescription": {
                "text": "Unresolved TODO, FIXME, or HACK comment found. Ensure this technical debt is tracked in Jira."
              },
              "help": {
                "text": "No remediation provided."
              }
            },
            {
              "id": "Semgrep-javascript.express.security.audit.xss.direct-response-write.direct-response-write",
              "shortDescription": {
                "text": "Detected directly writing to a Response object from user-defined input. This bypasses any HTML escap"
              },
              "fullDescription": {
                "text": "Detected directly writing to a Response object from user-defined input. This bypasses any HTML escaping and may expose your application to a Cross-Site-scripting (XSS) vulnerability. Instead, use 'resp.render()' to render safely escaped HTML."
              },
              "help": {
                "text": "No remediation provided."
              }
            },
            {
              "id": "Semgrep-javascript.lang.security.audit.code-string-concat.code-string-concat",
              "shortDescription": {
                "text": "Found data from an Express or Next web request flowing to `eval`. If this data is user-controllable "
              },
              "fullDescription": {
                "text": "Found data from an Express or Next web request flowing to `eval`. If this data is user-controllable this can lead to execution of arbitrary system commands in the context of your application process. Avoid `eval` whenever possible."
              },
              "help": {
                "text": "No remediation provided."
              }
