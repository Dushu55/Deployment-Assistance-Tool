            {
              "id": "Hadolint-DL3008",
              "shortDescription": {
                "text": "Pin versions in apt get install. Instead of `apt-get install <package>` use `apt-get install <packag"
              },
              "fullDescription": {
                "text": "Pin versions in apt get install. Instead of `apt-get install <package>` use `apt-get install <package>=<version>`"
