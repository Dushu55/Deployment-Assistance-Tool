{
  "name": "deployment-assist-tool",
  "version": "0.1.0",
  "description": "Pre-deployment quality, security, and container scanning CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dat": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/reporters/templates && cp -r src/reporters/templates/* dist/reporters/templates/",
    "start": "node dist/index.js",
    "start:app": "probot run ./dist/app.js",
    "dev": "tsx src/index.ts",
    "dev:app": "tsx node_modules/.bin/probot run ./src/app.ts",
    "test:webhook": "node scripts/simulate-webhook.js",
    "test": "tsx --test $(find src -name '*.test.ts' | sort)",
    "typecheck": "tsc --noEmit",
    "test:smoke": "bash scripts/smoke-test.sh",
    "test:e2e": "bash scripts/e2e-test.sh"
  },
  "dependencies": {
    "@ast-grep/cli": "^0.43.0",
    "@google/genai": "^2.6.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ejs": "^6.0.1",
    "probot": "^14.3.2",
    "puppeteer": "^25.1.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2",
    "yaml": "^2.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^20.14.2",
    "@types/xml2js": "^0.4.14",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5"
  }
}
