# GitHub App Configuration (Probot)
APP_ID=
WEBHOOK_SECRET=development
PRIVATE_KEY=
# Use this when running locally with smee.io
# WEBHOOK_PROXY_URL=https://smee.io/your-unique-smee-url

# Ephemeral Deployments (GCP Cloud Run)
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_CLOUD_SQL_INSTANCE=project:region:instance
DB_USER=postgres
DB_PASS=
DB_NAME=dat_testing_db

# LLM Integrations (Auto-Distroless refactor + Component Evaluator LLM tier)
# DAT supports TWO programmatic Gemini backends. (The consumer "Google AI Pro" subscription does
# NOT provide API access and cannot be used here.)
#
#  Option A — Google AI Studio API key (simplest; free tier):
#    Get a key (starts with AIza...) at https://aistudio.google.com/apikey
GEMINI_API_KEY=
#
#  Option B — Vertex AI on your GCP project (reuses gcloud auth, bills through GCP):
#    Run `gcloud auth application-default login`, then set:
# GOOGLE_GENAI_USE_VERTEXAI=true
#    (project defaults to GCP_PROJECT_ID above / deployer.gcp.projectId; region to GCP_REGION)

# GitHub Agent (For Self-Healing PRs from CLI)
GITHUB_TOKEN=

# Hosted GitHub App authorization (all optional; empty = allow all)
# DAT_ALLOWED_ORGS=acme,globex          # only run for these orgs
# DAT_ALLOWED_REPOS=acme/app,acme/api   # only run for these repos (owner/name)
# DAT_RATE_LIMIT_PER_HOUR=20            # max webhook-triggered scans per repo per hour (0 disables)



